{
  "name": "theobase",
  "version": "0.2.0",
  "description": "SDA Church Management Platform",
  "type": "module",
  "workspaces": ["client"],
  "scripts": {
    "dev": "wrangler dev",
    "dev:client": "npm -w client run dev",
    "deploy": "wrangler deploy",
    "deploy:client": "npm -w client run build && wrangler pages deploy client/dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && npm -w client run typecheck",
    "typecheck:api": "tsc --noEmit",
    "db:generate": "drizzle-kit generate:sqlite",
    "db:migrate": "wrangler d1 migrations apply theobase-db-dev --local",
    "db:migrate:prod": "wrangler d1 migrations apply theobase-db --remote --env production",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.29.0",
    "hono": "^4.0.0",
    "jose": "^5.2.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240208.0",
    "drizzle-kit": "^0.20.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0",
    "wrangler": "^3.28.0"
  }
}
