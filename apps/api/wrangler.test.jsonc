{
  "$schema": "https://raw.githubusercontent.com/cloudflare/workers-sdk/main/packages/wrangler/config-schema.json",
  "name": "theobase-api",
  "main": "src/index.ts",
  "compatibility_date": "2025-06-19",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "APP_URL": "",
    "JWT_SECRET": "theobase-test-secret-32chars-min",
    "STRIPE_SECRET_KEY": "",
    "STRIPE_WEBHOOK_SECRET": "",
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "theobase-spd",
      "database_id": "f0498166-49c6-448f-8148-cb9790a8d558",
    },
  ],
  "r2_buckets": [
    {
      "binding": "STORAGE",
      "bucket_name": "theobase-receipts",
    },
  ],
}
